# Worker cron (stays in env; registered once at process start)
# every minute
WORKER_CRON_EXPR=* * * * *

# Backend runtime settings (OCR, AI, worker timeouts, API keys, etc.) are stored
# in the database and edited from the Settings page (PocketBase superuser login).
# On first boot only, the values below seed the initial app_settings record.
# After that, the Settings UI is authoritative and these are ignored.

# OCR_PROVIDER=google_vision or OCR_PROVIDER=mistral
OCR_PROVIDER=google_vision
# this is the language of the processing result (names, tags, document types, etc. will be translated to this language)
PROCESSING_RESULT_LANGUAGE=en

WORKER_TIMEOUT_SEC=300
# no auto retries by default
WORKER_MAX_RETRIES=0
EXTRACTION_PROMPT_VERSION=v1

# google_vision free tier limits: 1000 pages per month
GOOGLE_VISION_API_KEY=
# Mistral OCR free tier limits: apparantely 625 pages per minute
MISTRAL_API_KEY=
# MISTRAL_OCR_MODEL=mistral-ocr-latest
# MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
OCR_TIMEOUT_SEC=40

OPENAI_API_KEY=
# be sure that your model supports the language you set in PROCESSING_RESULT_LANGUAGE
OPENAI_MODEL=deepseek-v4-flash
# Optional; defaults to OPENAI_MODEL when unset
OPENAI_CHAT_MODEL=
# Optional; defaults to OPENAI_CHAT_MODEL (then OPENAI_MODEL) when unset
OPENAI_SEARCH_MODEL=
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
OPENAI_TIMEOUT_SEC=60
# Comma-separated ISO 639-1 codes for Deep Search keyword expansion (e.g. de,en,uk)
DEEP_SEARCH_LANGUAGES=


# Frontend
VITE_POCKETBASE_URL=http://127.0.0.1:8090
VITE_DEV_USER_EMAIL=dev@paperless.local
VITE_DEV_USER_PASSWORD=devpassword123
